{
  "cleanUrls": true,
  "redirects": [
    { "source": "/treasury", "destination": "/#section-treasury", "permanent": false },
    { "source": "/signals",  "destination": "/#section-signals",  "permanent": false },
    { "source": "/rewards",  "destination": "/#section-rewards",  "permanent": false },
    { "source": "/keys",     "destination": "/#section-keys",     "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
